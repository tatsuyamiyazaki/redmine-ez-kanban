<% html_title l(:label_ez_kanban) %>

<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'ez_kanban', plugin: 'redmine_ez_kanban' %>
<% end %>

<h2><%= l(:label_ez_kanban) %></h2>

<%= render partial: 'filters' %>

<%# Active parent scope (R3): show what the board is scoped to and a control to
    clear it, returning to the full flat board while keeping the other URL
    params (active query/filter, subproject toggle). %>
<% if @scope_issue %>
  <div class="ez-kanban-scope">
    <span class="ez-kanban-scope__label">
      <%= l(:label_ez_kanban_scoped_to, subject: @scope_issue.subject) %>
    </span>
    <%= link_to l(:button_ez_kanban_clear_scope),
                project_ez_kanban_path(@project, request.query_parameters.except('scope_issue_id')),
                class: 'ez-kanban-scope__clear icon icon-del' %>
  </div>
<% end %>

<%# Freshness controls (issue 0009): a manual refresh button plus an opt-in
    polling-interval selector (default off). Both are driven by ez_kanban_board.js,
    which re-fetches the current URL (preserving filter/scope/subproject/cap
    state) and swaps only the board container's contents, keeping scroll. %>
<div class="ez-kanban-toolbar">
  <button type="button" id="ez-kanban-refresh" class="icon icon-reload">
    <%= l(:button_ez_kanban_refresh) %>
  </button>
  <label for="ez-kanban-poll-interval"><%= l(:label_ez_kanban_poll_interval) %></label>
  <%= select_tag 'ez_kanban_poll_interval',
        options_for_select(
          [[l(:label_ez_kanban_poll_off), '0'], ['30s', '30'],
           ['60s', '60'], ['120s', '120']], '0'),
        id: 'ez-kanban-poll-interval' %>
</div>

<div id="ez-kanban-board-container">
  <%= render partial: 'board' %>
</div>

<%= javascript_include_tag 'ez_kanban_board', plugin: 'redmine_ez_kanban' %>
